{
  "name": "yuansu-assets-platform",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.14.1",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "postinstall": "prisma generate",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "tsx scripts/run-tests.ts",
    "test:unit": "node --import tsx --test tests/auth-roles.test.ts tests/navigation.test.ts",
    "test:integration": "tsx scripts/run-tests.ts",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:migrate": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "db:reset:test": "tsx scripts/reset-test-database.ts",
    "auth:outbox": "tsx scripts/read-local-auth-outbox.ts"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "dotenv": "^17.4.2",
    "next": "16.2.10",
    "pg": "^8.22.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "server-only": "0.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "24.13.3",
    "@types/pg": "^8.20.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "autoprefixer": "10.5.2",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.10",
    "postcss": "8.5.18",
    "prisma": "^7.8.0",
    "tailwindcss": "3.4.19",
    "tsx": "^4.23.1",
    "typescript": "6.0.3"
  },
  "overrides": {
    "@hono/node-server": "1.19.13",
    "next": {
      "postcss": "8.5.18"
    }
  }
}
