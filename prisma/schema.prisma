generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserStatus {
  active
  disabled
  deleted

  @@map("user_status")
}

enum AuthProvider {
  phone
  email
  wechat

  @@map("auth_provider")
}

enum UserRole {
  buyer
  uploader
  admin
  observer

  @@map("user_role")
}

enum AdminRole {
  super_admin
  operator
  finance

  @@map("admin_role")
}

enum InviteCodeStatus {
  unused
  used
  disabled
  expired

  @@map("invite_code_status")
}

enum LegalDocumentType {
  terms_of_service
  privacy_policy
  commercial_license

  @@map("legal_document_type")
}

enum AuthChallengePurpose {
  register
  login

  @@map("auth_challenge_purpose")
}

enum AssetType {
  person
  object
  scene

  @@map("asset_type")
}

enum AssetReviewStatus {
  draft
  pending_review
  approved
  rejected

  @@map("asset_review_status")
}

enum AssetListingStatus {
  unlisted
  listed
  delisted

  @@map("asset_listing_status")
}

enum CertificationStatus {
  not_started
  pending_payment
  pending_review
  certifying
  certified
  exception

  @@map("certification_status")
}

enum AssetFileType {
  original
  preview
  thumbnail
  person_proof
  supporting_proof
  certificate_file
  certificate_snapshot
  download_bundle

  @@map("asset_file_type")
}

enum FileAccessScope {
  private
  public_preview
  signed_download_only

  @@map("file_access_scope")
}

enum UploadIntentStatus {
  pending
  completed
  expired
  rejected

  @@map("upload_intent_status")
}

enum AssetProcessingStatus {
  pending
  processing
  ready
  failed

  @@map("asset_processing_status")
}

enum PaymentStatus {
  pending
  success
  failed
  closed
  refunded

  @@map("payment_status")
}

enum RefundStatus {
  pending
  success
  failed
  cancelled

  @@map("refund_status")
}

enum OrderStatus {
  pending_payment
  paid
  cancelled
  payment_failed
  refunded
  partial_refunded

  @@map("order_status")
}

enum PaymentPurpose {
  asset_purchase
  certification_fee

  @@map("payment_purpose")
}

enum PaymentProvider {
  wechat_pay
  alipay

  @@map("payment_provider")
}

enum RefundPurpose {
  asset_purchase
  certification_fee

  @@map("refund_purpose")
}

enum AuthorizationStatus {
  active
  revoked

  @@map("authorization_status")
}

enum DownloadBundleStatus {
  pending
  processing
  ready
  failed

  @@map("download_bundle_status")
}

enum DownloadStatus {
  active
  expired
  revoked

  @@map("download_status")
}

enum RevenueRecordType {
  initial
  reversal

  @@map("revenue_record_type")
}

enum RevenueStatus {
  recorded
  reversed
  settled_pending
  settled

  @@map("revenue_status")
}

enum SnapshotPeriodType {
  day
  week
  month
  custom

  @@map("snapshot_period_type")
}

enum ObserverShareStatus {
  pending_confirm
  pending_settlement
  settled
  reversed

  @@map("observer_share_status")
}

model User {
  id                 String       @id @default(uuid()) @db.Uuid
  displayName        String       @map("display_name")
  email              String?      @unique
  phone              String?      @unique
  avatarUrl          String?      @map("avatar_url")
  primaryLoginMethod AuthProvider @map("primary_login_method")
  status             UserStatus   @default(active)
  lastLoginAt        DateTime?    @map("last_login_at") @db.Timestamptz(3)
  createdAt          DateTime     @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt          DateTime     @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt          DateTime?    @map("deleted_at") @db.Timestamptz(3)

  authIdentities              AuthIdentity[]
  termsAcceptances            UserTermsAcceptance[]
  roleMemberships             UserRoleMembership[]
  uploaderProfile             UploaderProfile?
  inviteCodesCreated          InviteCode[]                 @relation("InviteCreatedBy")
  inviteCodesUsed             InviteCode[]                 @relation("InviteUsedBy")
  adminRoleAssignments        AdminRoleAssignment[]        @relation("AdminRoleUser")
  adminRoleAssignmentsCreated AdminRoleAssignment[]        @relation("AdminRoleCreatedBy")
  observerProfile             ObserverProfile?
  sessions                    UserSession[]
  assetFilesUploaded          AssetFile[]                  @relation("AssetFileUploadedBy")
  assetsReviewed              Asset[]                      @relation("AssetReviewedBy")
  assetReviewEvents           AssetReviewEvent[]
  certificationsVerified      CertificationRecord[]        @relation("CertificationVerifiedBy")
  certificationRefundRequests CertificationRefundRequest[] @relation("CertificationRefundRequestedBy")
  auditLogs                   AuditLog[]
  uploadIntents               UploadIntent[]
  certificationFeeCharges     CertificationFeeCharge[]
  idempotencyRecords          IdempotencyRecord[]
  systemSettingsUpdated       SystemSetting[]              @relation("SystemSettingUpdatedBy")
  orders                      Order[]                      @relation("OrderBuyer")
  payments                    Payment[]                    @relation("PaymentPayer")
  refundsRequested            Refund[]                     @relation("RefundRequestedBy")
  refundsProcessed            Refund[]                     @relation("RefundProcessedBy")
  authorizationRecords        AuthorizationRecord[]        @relation("AuthorizationBuyer")
  authorizationsRevoked       AuthorizationRecord[]        @relation("AuthorizationRevokedBy")
  downloadLinksRequested      DownloadLink[]               @relation("DownloadLinkRequestedBy")
  downloads                   Download[]
  observerShareRecordsHandled ObserverShareRecord[]       @relation("ObserverShareHandledBy")

  @@index([status, createdAt])
  @@map("users")
}

model AuthIdentity {
  id              String       @id @default(uuid()) @db.Uuid
  userId          String       @map("user_id") @db.Uuid
  provider        AuthProvider
  providerSubject String       @map("provider_subject")
  isVerified      Boolean      @default(false) @map("is_verified")
  verifiedAt      DateTime?    @map("verified_at") @db.Timestamptz(3)
  metadata        Json         @default("{}")
  createdAt       DateTime     @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt       DateTime     @updatedAt @map("updated_at") @db.Timestamptz(3)
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerSubject])
  @@index([userId, provider])
  @@map("auth_identities")
}

model LegalDocumentVersion {
  id           String            @id @default(uuid()) @db.Uuid
  documentType LegalDocumentType @map("document_type")
  version      String
  title        String
  content      String
  contentHash  String            @map("content_hash")
  effectiveAt  DateTime          @map("effective_at") @db.Timestamptz(3)
  retiredAt    DateTime?         @map("retired_at") @db.Timestamptz(3)
  createdAt    DateTime          @default(now()) @map("created_at") @db.Timestamptz(3)

  acceptances UserTermsAcceptance[]

  @@unique([documentType, version])
  @@index([documentType, effectiveAt, retiredAt])
  @@map("legal_document_versions")
}

model UserTermsAcceptance {
  id                     String               @id @default(uuid()) @db.Uuid
  userId                 String               @map("user_id") @db.Uuid
  legalDocumentVersionId String               @map("legal_document_version_id") @db.Uuid
  acceptedAt             DateTime             @default(now()) @map("accepted_at") @db.Timestamptz(3)
  source                 String
  requestId              String?              @map("request_id")
  user                   User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  legalDocumentVersion   LegalDocumentVersion @relation(fields: [legalDocumentVersionId], references: [id])

  @@unique([userId, legalDocumentVersionId])
  @@index([userId, acceptedAt])
  @@map("user_terms_acceptances")
}

model UserRoleMembership {
  id        String     @id @default(uuid()) @db.Uuid
  userId    String     @map("user_id") @db.Uuid
  role      UserRole
  status    UserStatus @default(active)
  createdAt DateTime   @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime   @updatedAt @map("updated_at") @db.Timestamptz(3)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role])
  @@index([role, status])
  @@map("user_role_memberships")
}

model UploaderProfile {
  id           String          @id @default(uuid()) @db.Uuid
  userId       String          @unique @map("user_id") @db.Uuid
  inviteCodeId String          @unique @map("invite_code_id") @db.Uuid
  displayName  String          @map("display_name")
  bio          String?
  status       UserStatus      @default(active)
  createdAt    DateTime        @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt    DateTime        @updatedAt @map("updated_at") @db.Timestamptz(3)
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  inviteCode   InviteCode      @relation(fields: [inviteCodeId], references: [id])
  assets       Asset[]
  orderItems   OrderItem[]
  revenues     RevenueRecord[]

  @@map("uploader_profiles")
}

model InviteCode {
  id              String           @id @default(uuid()) @db.Uuid
  codeHash        String           @unique @map("code_hash")
  codeCiphertext  String?          @map("code_ciphertext")
  displayPrefix   String           @map("display_prefix")
  note            String?
  status          InviteCodeStatus @default(unused)
  createdByUserId String           @map("created_by_user_id") @db.Uuid
  usedByUserId    String?          @map("used_by_user_id") @db.Uuid
  usedAt          DateTime?        @map("used_at") @db.Timestamptz(3)
  expiresAt       DateTime?        @map("expires_at") @db.Timestamptz(3)
  createdAt       DateTime         @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt       DateTime         @updatedAt @map("updated_at") @db.Timestamptz(3)
  createdBy       User             @relation("InviteCreatedBy", fields: [createdByUserId], references: [id])
  usedBy          User?            @relation("InviteUsedBy", fields: [usedByUserId], references: [id])
  uploaderProfile UploaderProfile?

  @@index([status, expiresAt])
  @@map("invite_codes")
}

model AdminRoleAssignment {
  id              String     @id @default(uuid()) @db.Uuid
  userId          String     @map("user_id") @db.Uuid
  adminRole       AdminRole  @map("admin_role")
  status          UserStatus @default(active)
  createdByUserId String?    @map("created_by_user_id") @db.Uuid
  createdAt       DateTime   @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt       DateTime   @updatedAt @map("updated_at") @db.Timestamptz(3)
  user            User       @relation("AdminRoleUser", fields: [userId], references: [id], onDelete: Cascade)
  createdBy       User?      @relation("AdminRoleCreatedBy", fields: [createdByUserId], references: [id])

  @@unique([userId, adminRole])
  @@index([adminRole, status])
  @@map("admin_role_assignments")
}

model ObserverProfile {
  id               String     @id @default(uuid()) @db.Uuid
  userId           String     @unique @map("user_id") @db.Uuid
  partnerName      String     @map("partner_name")
  defaultShareRate Decimal    @default(0) @map("default_share_rate") @db.Decimal(6, 4)
  status           UserStatus @default(active)
  createdAt        DateTime   @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt        DateTime   @updatedAt @map("updated_at") @db.Timestamptz(3)
  user             User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  shareRecords     ObserverShareRecord[]

  @@map("observer_profiles")
}

model UserSession {
  id            String    @id @default(uuid()) @db.Uuid
  userId        String    @map("user_id") @db.Uuid
  tokenHash     String    @unique @map("token_hash")
  csrfTokenHash String?   @map("csrf_token_hash")
  csrfExpiresAt DateTime? @map("csrf_expires_at") @db.Timestamptz(3)
  expiresAt     DateTime  @map("expires_at") @db.Timestamptz(3)
  revokedAt     DateTime? @map("revoked_at") @db.Timestamptz(3)
  lastSeenAt    DateTime  @default(now()) @map("last_seen_at") @db.Timestamptz(3)
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([expiresAt, revokedAt])
  @@map("user_sessions")
}

model AuthChallenge {
  id             String               @id @default(uuid()) @db.Uuid
  provider       AuthProvider
  identifier     String
  identifierHash String               @map("identifier_hash")
  purpose        AuthChallengePurpose
  codeHash       String               @map("code_hash")
  attempts       Int                  @default(0)
  maxAttempts    Int                  @default(5) @map("max_attempts")
  expiresAt      DateTime             @map("expires_at") @db.Timestamptz(3)
  consumedAt     DateTime?            @map("consumed_at") @db.Timestamptz(3)
  createdAt      DateTime             @default(now()) @map("created_at") @db.Timestamptz(3)

  @@index([identifierHash, purpose, createdAt])
  @@index([expiresAt, consumedAt])
  @@map("auth_challenges")
}

model Asset {
  id                         String                      @id @default(uuid()) @db.Uuid
  uploaderProfileId          String                      @map("uploader_profile_id") @db.Uuid
  assetType                  AssetType                   @map("asset_type")
  title                      String
  description                String?
  category                   String?
  reviewStatus               AssetReviewStatus           @default(draft) @map("review_status")
  listingStatus              AssetListingStatus          @default(unlisted) @map("listing_status")
  certificationStatus        CertificationStatus         @default(not_started) @map("certification_status")
  priceCents                 Int                         @map("price_cents")
  currency                   String                      @default("CNY")
  rejectionReason            String?                     @map("rejection_reason")
  submittedAt                DateTime?                   @map("submitted_at") @db.Timestamptz(3)
  reviewedByUserId           String?                     @map("reviewed_by_user_id") @db.Uuid
  reviewedAt                 DateTime?                   @map("reviewed_at") @db.Timestamptz(3)
  listedAt                   DateTime?                   @map("listed_at") @db.Timestamptz(3)
  createdAt                  DateTime                    @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt                  DateTime                    @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt                  DateTime?                   @map("deleted_at") @db.Timestamptz(3)
  uploaderProfile            UploaderProfile             @relation(fields: [uploaderProfileId], references: [id])
  reviewedBy                 User?                       @relation("AssetReviewedBy", fields: [reviewedByUserId], references: [id])
  tags                       AssetTag[]
  files                      AssetFile[]
  uploadIntents              UploadIntent[]
  processingJobs             AssetDerivativeJob[]
  certificationFeeCharge     CertificationFeeCharge?
  reviewEvents               AssetReviewEvent[]
  certificationRecord        CertificationRecord?
  certificationRefundRequest CertificationRefundRequest?
  auditLogs                  AuditLog[]
  orderItems                 OrderItem[]
  authorizationRecords       AuthorizationRecord[]
  revenueRecords             RevenueRecord[]
  downloads                  Download[]

  @@index([assetType, listingStatus, certificationStatus])
  @@index([uploaderProfileId, createdAt])
  @@index([reviewStatus, createdAt])
  @@index([listingStatus, listedAt, id])
  @@map("assets")
}

model AssetTag {
  id        String   @id @default(uuid()) @db.Uuid
  assetId   String   @map("asset_id") @db.Uuid
  tag       String
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  asset     Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([assetId, tag])
  @@index([tag])
  @@map("asset_tags")
}

model AssetFile {
  id                     String                @id @default(uuid()) @db.Uuid
  assetId                String                @map("asset_id") @db.Uuid
  uploadedByUserId       String                @map("uploaded_by_user_id") @db.Uuid
  fileType               AssetFileType         @map("file_type")
  accessScope            FileAccessScope       @map("access_scope")
  cosBucket              String                @map("cos_bucket")
  cosRegion              String                @map("cos_region")
  cosObjectKey           String                @map("cos_object_key")
  fileHash               String                @map("file_hash")
  fileSizeBytes          BigInt                @map("file_size_bytes")
  mimeType               String                @map("mime_type")
  width                  Int?
  height                 Int?
  metadata               Json                  @default("{}")
  createdAt              DateTime              @default(now()) @map("created_at") @db.Timestamptz(3)
  deletedAt              DateTime?             @map("deleted_at") @db.Timestamptz(3)
  asset                  Asset                 @relation(fields: [assetId], references: [id], onDelete: Cascade)
  uploadedBy             User                  @relation("AssetFileUploadedBy", fields: [uploadedByUserId], references: [id])
  completedUploadIntent  UploadIntent?
  derivativeSourceJobs   AssetDerivativeJob[]  @relation("DerivativeSourceFile")
  certificateFileFor     CertificationRecord[] @relation("CertificationFile")
  certificateSnapshotFor CertificationRecord[] @relation("CertificationSnapshotFile")
  downloadLinks          DownloadLink[]        @relation("DownloadBundleFile")
  downloads              Download[]

  @@unique([cosBucket, cosRegion, cosObjectKey])
  @@index([assetId, fileType])
  @@index([fileHash])
  @@map("asset_files")
}

model UploadIntent {
  id               String             @id @default(uuid()) @db.Uuid
  assetId          String             @map("asset_id") @db.Uuid
  userId           String             @map("user_id") @db.Uuid
  fileType         AssetFileType      @map("file_type")
  provider         String
  status           UploadIntentStatus @default(pending)
  fileName         String             @map("file_name")
  mimeType         String             @map("mime_type")
  sizeBytes        BigInt             @map("size_bytes")
  sha256           String
  stagingBucket    String             @map("staging_bucket")
  stagingRegion    String             @map("staging_region")
  stagingObjectKey String             @map("staging_object_key")
  finalBucket      String             @map("final_bucket")
  finalRegion      String             @map("final_region")
  finalObjectKey   String             @map("final_object_key")
  expiresAt        DateTime           @map("expires_at") @db.Timestamptz(3)
  completedAt      DateTime?          @map("completed_at") @db.Timestamptz(3)
  assetFileId      String?            @unique @map("asset_file_id") @db.Uuid
  createdAt        DateTime           @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt        DateTime           @updatedAt @map("updated_at") @db.Timestamptz(3)
  asset            Asset              @relation(fields: [assetId], references: [id], onDelete: Cascade)
  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  assetFile        AssetFile?         @relation(fields: [assetFileId], references: [id])

  @@unique([stagingBucket, stagingRegion, stagingObjectKey])
  @@unique([finalBucket, finalRegion, finalObjectKey])
  @@index([assetId, status, createdAt])
  @@index([userId, createdAt])
  @@index([expiresAt, status])
  @@map("upload_intents")
}

model AssetDerivativeJob {
  id                       String                @id @default(uuid()) @db.Uuid
  assetId                  String                @map("asset_id") @db.Uuid
  sourceFileId             String                @map("source_file_id") @db.Uuid
  provider                 String
  status                   AssetProcessingStatus @default(pending)
  watermarkTemplateVersion String                @map("watermark_template_version")
  attempts                 Int                   @default(0)
  errorCode                String?               @map("error_code")
  startedAt                DateTime?             @map("started_at") @db.Timestamptz(3)
  completedAt              DateTime?             @map("completed_at") @db.Timestamptz(3)
  createdAt                DateTime              @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt                DateTime              @updatedAt @map("updated_at") @db.Timestamptz(3)
  asset                    Asset                 @relation(fields: [assetId], references: [id], onDelete: Cascade)
  sourceFile               AssetFile             @relation("DerivativeSourceFile", fields: [sourceFileId], references: [id], onDelete: Cascade)

  @@unique([sourceFileId, watermarkTemplateVersion])
  @@index([assetId, status, createdAt])
  @@index([status, createdAt])
  @@map("asset_derivative_jobs")
}

model CertificationFeeCharge {
  id               String                      @id @default(uuid()) @db.Uuid
  assetId          String                      @unique @map("asset_id") @db.Uuid
  uploaderUserId   String                      @map("uploader_user_id") @db.Uuid
  amountCents      Int                         @default(1000) @map("amount_cents")
  currency         String                      @default("CNY")
  status           PaymentStatus               @default(pending)
  settingsSnapshot Json                        @default("{}") @map("settings_snapshot")
  paidAt           DateTime?                   @map("paid_at") @db.Timestamptz(3)
  createdAt        DateTime                    @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt        DateTime                    @updatedAt @map("updated_at") @db.Timestamptz(3)
  asset            Asset                       @relation(fields: [assetId], references: [id])
  uploaderUser     User                        @relation(fields: [uploaderUserId], references: [id])
  refundRequest    CertificationRefundRequest?
  payments         Payment[]
  refunds          Refund[]

  @@index([uploaderUserId, createdAt])
  @@index([status, createdAt])
  @@map("certification_fee_charges")
}

model AssetReviewEvent {
  id          String             @id @default(uuid()) @db.Uuid
  assetId     String             @map("asset_id") @db.Uuid
  fromStatus  AssetReviewStatus? @map("from_status")
  toStatus    AssetReviewStatus  @map("to_status")
  actorUserId String             @map("actor_user_id") @db.Uuid
  reason      String?
  createdAt   DateTime           @default(now()) @map("created_at") @db.Timestamptz(3)
  asset       Asset              @relation(fields: [assetId], references: [id], onDelete: Cascade)
  actor       User               @relation(fields: [actorUserId], references: [id])

  @@index([assetId, createdAt])
  @@index([actorUserId, createdAt])
  @@map("asset_review_events")
}

model CertificationRecord {
  id                        String              @id @default(uuid()) @db.Uuid
  assetId                   String              @unique @map("asset_id") @db.Uuid
  status                    CertificationStatus @default(certifying)
  governmentSiteName        String?             @map("government_site_name")
  certificateNo             String?             @map("certificate_no")
  credential                String?
  certificateFileId         String?             @map("certificate_file_id") @db.Uuid
  certificateSnapshotFileId String?             @map("certificate_snapshot_file_id") @db.Uuid
  certificateIssuedAt       DateTime?           @map("certificate_issued_at") @db.Timestamptz(3)
  certificationStartedAt    DateTime?           @map("certification_started_at") @db.Timestamptz(3)
  verifiedByUserId          String?             @map("verified_by_user_id") @db.Uuid
  verifiedAt                DateTime?           @map("verified_at") @db.Timestamptz(3)
  notes                     String?
  createdAt                 DateTime            @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt                 DateTime            @updatedAt @map("updated_at") @db.Timestamptz(3)
  asset                     Asset               @relation(fields: [assetId], references: [id], onDelete: Cascade)
  certificateFile           AssetFile?          @relation("CertificationFile", fields: [certificateFileId], references: [id])
  certificateSnapshotFile   AssetFile?          @relation("CertificationSnapshotFile", fields: [certificateSnapshotFileId], references: [id])
  verifiedBy                User?               @relation("CertificationVerifiedBy", fields: [verifiedByUserId], references: [id])

  @@index([status, createdAt])
  @@map("certification_records")
}

model CertificationRefundRequest {
  id                       String                 @id @default(uuid()) @db.Uuid
  assetId                  String                 @unique @map("asset_id") @db.Uuid
  certificationFeeChargeId String                 @unique @map("certification_fee_charge_id") @db.Uuid
  amountCents              Int                    @map("amount_cents")
  currency                 String                 @default("CNY")
  reason                   String
  status                   RefundStatus           @default(pending)
  requestedByUserId        String                 @map("requested_by_user_id") @db.Uuid
  requestedAt              DateTime               @default(now()) @map("requested_at") @db.Timestamptz(3)
  createdAt                DateTime               @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt                DateTime               @updatedAt @map("updated_at") @db.Timestamptz(3)
  asset                    Asset                  @relation(fields: [assetId], references: [id])
  certificationFeeCharge   CertificationFeeCharge @relation(fields: [certificationFeeChargeId], references: [id])
  requestedBy              User                   @relation("CertificationRefundRequestedBy", fields: [requestedByUserId], references: [id])
  refund                   Refund?

  @@index([status, requestedAt])
  @@map("certification_refund_requests")
}

model Order {
  id               String                @id @default(uuid()) @db.Uuid
  orderNo          String                @unique @map("order_no")
  buyerUserId      String                @map("buyer_user_id") @db.Uuid
  status           OrderStatus           @default(pending_payment)
  totalAmountCents Int                   @map("total_amount_cents")
  currency         String                @default("CNY")
  settingsSnapshot Json                  @default("{}") @map("settings_snapshot")
  paidAt           DateTime?             @map("paid_at") @db.Timestamptz(3)
  cancelledAt      DateTime?             @map("cancelled_at") @db.Timestamptz(3)
  createdAt        DateTime              @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt        DateTime              @updatedAt @map("updated_at") @db.Timestamptz(3)
  buyer            User                  @relation("OrderBuyer", fields: [buyerUserId], references: [id])
  items            OrderItem[]
  payments         Payment[]
  refunds          Refund[]
  authorizations   AuthorizationRecord[]

  @@index([buyerUserId, createdAt])
  @@index([status, createdAt])
  @@map("orders")
}

model OrderItem {
  id                          String               @id @default(uuid()) @db.Uuid
  orderId                     String               @map("order_id") @db.Uuid
  assetId                     String               @map("asset_id") @db.Uuid
  uploaderProfileId           String               @map("uploader_profile_id") @db.Uuid
  assetTitleSnapshot          String               @map("asset_title_snapshot")
  assetTypeSnapshot           AssetType            @map("asset_type_snapshot")
  certificationStatusSnapshot CertificationStatus  @map("certification_status_snapshot")
  priceCents                  Int                  @map("price_cents")
  currency                    String               @default("CNY")
  createdAt                   DateTime             @default(now()) @map("created_at") @db.Timestamptz(3)
  order                       Order                @relation(fields: [orderId], references: [id], onDelete: Cascade)
  asset                       Asset                @relation(fields: [assetId], references: [id])
  uploaderProfile             UploaderProfile      @relation(fields: [uploaderProfileId], references: [id])
  authorization               AuthorizationRecord?
  refundItems                 RefundItem[]
  revenueRecords              RevenueRecord[]

  @@unique([orderId, assetId])
  @@index([assetId])
  @@index([uploaderProfileId])
  @@map("order_items")
}

model Payment {
  id                       String                  @id @default(uuid()) @db.Uuid
  paymentNo                String                  @unique @map("payment_no")
  purpose                  PaymentPurpose
  orderId                  String?                 @map("order_id") @db.Uuid
  certificationFeeChargeId String?                 @map("certification_fee_charge_id") @db.Uuid
  payerUserId              String                  @map("payer_user_id") @db.Uuid
  provider                 PaymentProvider
  providerMode             String                  @default("local_test") @map("provider_mode")
  merchantId               String                  @map("merchant_id")
  amountCents              Int                     @map("amount_cents")
  currency                 String                  @default("CNY")
  status                   PaymentStatus           @default(pending)
  providerTradeNo          String?                 @unique @map("provider_trade_no")
  providerPayloadSummary   Json                    @default("{}") @map("provider_payload_summary")
  paidAt                   DateTime?               @map("paid_at") @db.Timestamptz(3)
  failedReason             String?                 @map("failed_reason")
  createdAt                DateTime                @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt                DateTime                @updatedAt @map("updated_at") @db.Timestamptz(3)
  order                    Order?                  @relation(fields: [orderId], references: [id])
  certificationFeeCharge   CertificationFeeCharge? @relation(fields: [certificationFeeChargeId], references: [id])
  payer                    User                    @relation("PaymentPayer", fields: [payerUserId], references: [id])
  refunds                  Refund[]
  webhookEvents            WebhookEvent[]

  @@index([orderId])
  @@index([certificationFeeChargeId])
  @@index([payerUserId, createdAt])
  @@index([status, createdAt])
  @@map("payments")
}

model Refund {
  id                           String                      @id @default(uuid()) @db.Uuid
  refundNo                     String                      @unique @map("refund_no")
  purpose                      RefundPurpose
  paymentId                    String                      @map("payment_id") @db.Uuid
  orderId                      String?                     @map("order_id") @db.Uuid
  certificationFeeChargeId     String?                     @map("certification_fee_charge_id") @db.Uuid
  certificationRefundRequestId String?                     @unique @map("certification_refund_request_id") @db.Uuid
  amountCents                  Int                         @map("amount_cents")
  currency                     String                      @default("CNY")
  reason                       String
  status                       RefundStatus                @default(pending)
  providerRefundNo             String?                     @unique @map("provider_refund_no")
  requestedByUserId            String                      @map("requested_by_user_id") @db.Uuid
  requestedAt                  DateTime                    @default(now()) @map("requested_at") @db.Timestamptz(3)
  processedByUserId            String?                     @map("processed_by_user_id") @db.Uuid
  processedAt                  DateTime?                   @map("processed_at") @db.Timestamptz(3)
  createdAt                    DateTime                    @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt                    DateTime                    @updatedAt @map("updated_at") @db.Timestamptz(3)
  payment                      Payment                     @relation(fields: [paymentId], references: [id])
  order                        Order?                      @relation(fields: [orderId], references: [id])
  certificationFeeCharge       CertificationFeeCharge?     @relation(fields: [certificationFeeChargeId], references: [id])
  certificationRefundRequest   CertificationRefundRequest? @relation(fields: [certificationRefundRequestId], references: [id])
  requestedBy                  User                        @relation("RefundRequestedBy", fields: [requestedByUserId], references: [id])
  processedBy                  User?                       @relation("RefundProcessedBy", fields: [processedByUserId], references: [id])
  items                        RefundItem[]
  webhookEvents                WebhookEvent[]

  @@index([paymentId, createdAt])
  @@index([orderId])
  @@index([certificationFeeChargeId])
  @@index([status, createdAt])
  @@map("refunds")
}

model RefundItem {
  id          String    @id @default(uuid()) @db.Uuid
  refundId    String    @map("refund_id") @db.Uuid
  orderItemId String    @map("order_item_id") @db.Uuid
  amountCents Int       @map("amount_cents")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  refund      Refund    @relation(fields: [refundId], references: [id], onDelete: Cascade)
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id])

  @@unique([refundId, orderItemId])
  @@index([orderItemId])
  @@map("refund_items")
}

model AuthorizationRecord {
  id                          String              @id @default(uuid()) @db.Uuid
  buyerUserId                 String              @map("buyer_user_id") @db.Uuid
  orderId                     String              @map("order_id") @db.Uuid
  orderItemId                 String              @unique @map("order_item_id") @db.Uuid
  assetId                     String              @map("asset_id") @db.Uuid
  licenseVersion              String              @map("license_version")
  licenseTextSnapshot         String              @map("license_text_snapshot")
  certificationStatusSnapshot CertificationStatus @map("certification_status_snapshot")
  assetFileManifestSnapshot   Json                @map("asset_file_manifest_snapshot")
  status                      AuthorizationStatus @default(active)
  grantedAt                   DateTime            @default(now()) @map("granted_at") @db.Timestamptz(3)
  revokedAt                   DateTime?           @map("revoked_at") @db.Timestamptz(3)
  revokedByUserId             String?             @map("revoked_by_user_id") @db.Uuid
  revokeReason                String?             @map("revoke_reason")
  createdAt                   DateTime            @default(now()) @map("created_at") @db.Timestamptz(3)
  buyer                       User                @relation("AuthorizationBuyer", fields: [buyerUserId], references: [id])
  order                       Order               @relation(fields: [orderId], references: [id])
  orderItem                   OrderItem           @relation(fields: [orderItemId], references: [id])
  asset                       Asset               @relation(fields: [assetId], references: [id])
  revokedBy                   User?               @relation("AuthorizationRevokedBy", fields: [revokedByUserId], references: [id])
  downloadLinks               DownloadLink[]
  downloads                   Download[]

  @@index([buyerUserId, grantedAt])
  @@index([assetId])
  @@index([status, createdAt])
  @@map("authorization_records")
}

model DownloadLink {
  id                      String               @id @default(uuid()) @db.Uuid
  authorizationRecordId   String               @map("authorization_record_id") @db.Uuid
  downloadBundleFileId    String?              @unique @map("download_bundle_file_id") @db.Uuid
  bundleStatus            DownloadBundleStatus @default(pending) @map("bundle_status")
  bundleGeneratedAt       DateTime?            @map("bundle_generated_at") @db.Timestamptz(3)
  bundleFailureCode       String?              @map("bundle_failure_code")
  requestedByUserId       String               @map("requested_by_user_id") @db.Uuid
  eligibilityDaysSnapshot Int                  @map("eligibility_days_snapshot")
  expiresAt               DateTime             @map("expires_at") @db.Timestamptz(3)
  status                  DownloadStatus       @default(active)
  createdAt               DateTime             @default(now()) @map("created_at") @db.Timestamptz(3)
  authorizationRecord     AuthorizationRecord  @relation(fields: [authorizationRecordId], references: [id])
  downloadBundleFile      AssetFile?           @relation("DownloadBundleFile", fields: [downloadBundleFileId], references: [id])
  requestedBy             User                 @relation("DownloadLinkRequestedBy", fields: [requestedByUserId], references: [id])
  downloads               Download[]

  @@unique([authorizationRecordId])
  @@index([requestedByUserId, createdAt])
  @@index([status, expiresAt])
  @@map("download_links")
}

model Download {
  id                    String              @id @default(uuid()) @db.Uuid
  downloadLinkId        String              @map("download_link_id") @db.Uuid
  authorizationRecordId String              @map("authorization_record_id") @db.Uuid
  buyerUserId           String              @map("buyer_user_id") @db.Uuid
  assetId               String              @map("asset_id") @db.Uuid
  assetFileId           String              @map("asset_file_id") @db.Uuid
  downloadedAt          DateTime            @default(now()) @map("downloaded_at") @db.Timestamptz(3)
  ipHash                String?             @map("ip_hash")
  userAgentSummary      String?             @map("user_agent_summary")
  downloadLink          DownloadLink        @relation(fields: [downloadLinkId], references: [id])
  authorizationRecord   AuthorizationRecord @relation(fields: [authorizationRecordId], references: [id])
  buyer                 User                @relation(fields: [buyerUserId], references: [id])
  asset                 Asset               @relation(fields: [assetId], references: [id])
  assetFile             AssetFile           @relation(fields: [assetFileId], references: [id])

  @@index([buyerUserId, downloadedAt])
  @@index([assetId, downloadedAt])
  @@index([downloadLinkId, downloadedAt])
  @@map("downloads")
}

model RevenueRecord {
  id                     String            @id @default(uuid()) @db.Uuid
  orderItemId            String            @map("order_item_id") @db.Uuid
  recordType             RevenueRecordType @map("record_type")
  assetId                String            @map("asset_id") @db.Uuid
  uploaderProfileId      String            @map("uploader_profile_id") @db.Uuid
  grossAmountCents       Int               @map("gross_amount_cents")
  uploaderAmountCents    Int               @map("uploader_amount_cents")
  platformAmountCents    Int               @map("platform_amount_cents")
  uploaderShareRate      Decimal           @map("uploader_share_rate") @db.Decimal(6, 4)
  platformShareRate      Decimal           @map("platform_share_rate") @db.Decimal(6, 4)
  currency               String            @default("CNY")
  status                 RevenueStatus     @default(recorded)
  relatedRevenueRecordId String?           @unique @map("related_revenue_record_id") @db.Uuid
  createdAt              DateTime          @default(now()) @map("created_at") @db.Timestamptz(3)
  orderItem              OrderItem         @relation(fields: [orderItemId], references: [id])
  asset                  Asset             @relation(fields: [assetId], references: [id])
  uploaderProfile        UploaderProfile   @relation(fields: [uploaderProfileId], references: [id])
  relatedRevenueRecord   RevenueRecord?    @relation("RevenueReversal", fields: [relatedRevenueRecordId], references: [id])
  reversalRecord         RevenueRecord?    @relation("RevenueReversal")

  @@index([orderItemId])
  @@index([uploaderProfileId, createdAt])
  @@index([assetId])
  @@index([status, createdAt])
  @@map("revenue_records")
}

model PlatformMetricSnapshot {
  id                           String             @id @default(uuid()) @db.Uuid
  periodType                   SnapshotPeriodType @map("period_type")
  periodStart                  DateTime           @map("period_start") @db.Timestamptz(3)
  periodEnd                    DateTime           @map("period_end") @db.Timestamptz(3)
  totalUploadedAssets          Int                @map("total_uploaded_assets")
  newUploadedAssets            Int                @map("new_uploaded_assets")
  listedAssets                 Int                @map("listed_assets")
  delistedAssets               Int                @map("delisted_assets")
  pendingReviewAssets          Int                @map("pending_review_assets")
  certifiedAssets              Int                @map("certified_assets")
  certificationExceptionAssets Int                @map("certification_exception_assets")
  personAssetCount             Int                @map("person_asset_count")
  objectAssetCount             Int                @map("object_asset_count")
  sceneAssetCount              Int                @map("scene_asset_count")
  totalDownloads               Int                @map("total_downloads")
  paidDownloads                Int                @map("paid_downloads")
  paidOrderCount               Int                @map("paid_order_count")
  refundedOrderCount           Int                @map("refunded_order_count")
  authorizationRecordCount     Int                @map("authorization_record_count")
  grossOrderAmountCents        Int                @map("gross_order_amount_cents")
  paidOrderAmountCents         Int                @map("paid_order_amount_cents")
  refundAmountCents            Int                @map("refund_amount_cents")
  netRevenueCents              Int                @map("net_revenue_cents")
  platformShareAmountCents     Int                @map("platform_share_amount_cents")
  uploaderShareAmountCents     Int                @map("uploader_share_amount_cents")
  createdAt                    DateTime           @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt                    DateTime           @updatedAt @map("updated_at") @db.Timestamptz(3)
  assetTypeSnapshots           PlatformAssetTypeMetricSnapshot[]
  observerShareRecords         ObserverShareRecord[]

  @@unique([periodType, periodStart, periodEnd])
  @@index([periodStart, periodEnd])
  @@map("platform_metric_snapshots")
}

model PlatformAssetTypeMetricSnapshot {
  id               String                 @id @default(uuid()) @db.Uuid
  metricSnapshotId String                 @map("metric_snapshot_id") @db.Uuid
  assetType        AssetType              @map("asset_type")
  uploadedAssets   Int                    @map("uploaded_assets")
  listedAssets     Int                    @map("listed_assets")
  certifiedAssets  Int                    @map("certified_assets")
  downloads        Int
  createdAt        DateTime               @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt        DateTime               @updatedAt @map("updated_at") @db.Timestamptz(3)
  metricSnapshot   PlatformMetricSnapshot @relation(fields: [metricSnapshotId], references: [id], onDelete: Cascade)

  @@unique([metricSnapshotId, assetType])
  @@index([assetType, createdAt])
  @@map("platform_asset_type_metric_snapshots")
}

model ObserverShareRecord {
  id                         String                 @id @default(uuid()) @db.Uuid
  observerProfileId          String                 @map("observer_profile_id") @db.Uuid
  metricSnapshotId           String                 @map("metric_snapshot_id") @db.Uuid
  periodStart                DateTime               @map("period_start") @db.Timestamptz(3)
  periodEnd                  DateTime               @map("period_end") @db.Timestamptz(3)
  shareBaseAmountCents       Int                    @map("share_base_amount_cents")
  shareRate                  Decimal                @default(0) @map("share_rate") @db.Decimal(6, 4)
  expectedShareAmountCents   Int                    @default(0) @map("expected_share_amount_cents")
  settledShareAmountCents    Int                    @default(0) @map("settled_share_amount_cents")
  pendingShareAmountCents    Int                    @default(0) @map("pending_share_amount_cents")
  status                     ObserverShareStatus    @default(pending_confirm)
  handledByUserId            String?                @map("handled_by_user_id") @db.Uuid
  settledAt                  DateTime?              @map("settled_at") @db.Timestamptz(3)
  createdAt                  DateTime               @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt                  DateTime               @updatedAt @map("updated_at") @db.Timestamptz(3)
  observerProfile            ObserverProfile        @relation(fields: [observerProfileId], references: [id], onDelete: Cascade)
  metricSnapshot             PlatformMetricSnapshot @relation(fields: [metricSnapshotId], references: [id], onDelete: Cascade)
  handledBy                  User?                  @relation("ObserverShareHandledBy", fields: [handledByUserId], references: [id])

  @@unique([observerProfileId, metricSnapshotId])
  @@index([observerProfileId, periodStart, periodEnd])
  @@index([status, createdAt])
  @@map("observer_share_records")
}

model WebhookEvent {
  id              String          @id @default(uuid()) @db.Uuid
  provider        PaymentProvider
  providerMode    String          @default("local_test") @map("provider_mode")
  providerEventId String          @map("provider_event_id")
  eventType       String          @map("event_type")
  paymentId       String?         @map("payment_id") @db.Uuid
  refundId        String?         @map("refund_id") @db.Uuid
  payloadHash     String          @map("payload_hash")
  processedAt     DateTime        @default(now()) @map("processed_at") @db.Timestamptz(3)
  createdAt       DateTime        @default(now()) @map("created_at") @db.Timestamptz(3)
  payment         Payment?        @relation(fields: [paymentId], references: [id])
  refund          Refund?         @relation(fields: [refundId], references: [id])

  @@unique([provider, providerEventId])
  @@index([paymentId])
  @@index([refundId])
  @@map("webhook_events")
}

model AuditLog {
  id          String   @id @default(uuid()) @db.Uuid
  actorUserId String   @map("actor_user_id") @db.Uuid
  action      String
  targetType  String   @map("target_type")
  targetId    String?  @map("target_id") @db.Uuid
  assetId     String?  @map("asset_id") @db.Uuid
  requestId   String?  @map("request_id")
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  actor       User     @relation(fields: [actorUserId], references: [id])
  asset       Asset?   @relation(fields: [assetId], references: [id], onDelete: SetNull)

  @@index([actorUserId, createdAt])
  @@index([assetId, createdAt])
  @@index([action, createdAt])
  @@map("audit_logs")
}

model SystemSetting {
  id              String   @id @default(uuid()) @db.Uuid
  key             String   @unique
  value           Json
  description     String?
  updatedByUserId String?  @map("updated_by_user_id") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)
  updatedBy       User?    @relation("SystemSettingUpdatedBy", fields: [updatedByUserId], references: [id])

  @@map("system_settings")
}

model IdempotencyRecord {
  id                 String   @id @default(uuid()) @db.Uuid
  userId             String   @map("user_id") @db.Uuid
  endpoint           String
  idempotencyKeyHash String   @map("idempotency_key_hash")
  requestHash        String   @map("request_hash")
  responseResourceId String   @map("response_resource_id") @db.Uuid
  expiresAt          DateTime @map("expires_at") @db.Timestamptz(3)
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, endpoint, idempotencyKeyHash])
  @@index([expiresAt])
  @@map("idempotency_records")
}
