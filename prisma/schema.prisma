generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserStatus {
  active
  disabled
  deleted

  @@map("user_status")
}

enum AuthProvider {
  phone
  email
  wechat

  @@map("auth_provider")
}

enum UserRole {
  buyer
  uploader
  admin
  observer

  @@map("user_role")
}

enum AdminRole {
  super_admin
  operator
  finance

  @@map("admin_role")
}

enum InviteCodeStatus {
  unused
  used
  disabled
  expired

  @@map("invite_code_status")
}

enum LegalDocumentType {
  terms_of_service
  privacy_policy
  commercial_license

  @@map("legal_document_type")
}

enum AuthChallengePurpose {
  register
  login

  @@map("auth_challenge_purpose")
}

model User {
  id                 String       @id @default(uuid()) @db.Uuid
  displayName        String       @map("display_name")
  email              String?      @unique
  phone              String?      @unique
  avatarUrl          String?      @map("avatar_url")
  primaryLoginMethod AuthProvider @map("primary_login_method")
  status             UserStatus   @default(active)
  lastLoginAt        DateTime?    @map("last_login_at") @db.Timestamptz(3)
  createdAt          DateTime     @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt          DateTime     @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt          DateTime?    @map("deleted_at") @db.Timestamptz(3)

  authIdentities             AuthIdentity[]
  termsAcceptances           UserTermsAcceptance[]
  roleMemberships            UserRoleMembership[]
  uploaderProfile            UploaderProfile?
  inviteCodesCreated         InviteCode[]          @relation("InviteCreatedBy")
  inviteCodesUsed            InviteCode[]          @relation("InviteUsedBy")
  adminRoleAssignments       AdminRoleAssignment[] @relation("AdminRoleUser")
  adminRoleAssignmentsCreated AdminRoleAssignment[] @relation("AdminRoleCreatedBy")
  observerProfile            ObserverProfile?
  sessions                   UserSession[]

  @@index([status, createdAt])
  @@map("users")
}

model AuthIdentity {
  id              String       @id @default(uuid()) @db.Uuid
  userId          String       @map("user_id") @db.Uuid
  provider        AuthProvider
  providerSubject String       @map("provider_subject")
  isVerified      Boolean      @default(false) @map("is_verified")
  verifiedAt      DateTime?    @map("verified_at") @db.Timestamptz(3)
  metadata        Json         @default("{}")
  createdAt       DateTime     @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt       DateTime     @updatedAt @map("updated_at") @db.Timestamptz(3)
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerSubject])
  @@index([userId, provider])
  @@map("auth_identities")
}

model LegalDocumentVersion {
  id           String            @id @default(uuid()) @db.Uuid
  documentType LegalDocumentType @map("document_type")
  version      String
  title        String
  content      String
  contentHash  String            @map("content_hash")
  effectiveAt  DateTime          @map("effective_at") @db.Timestamptz(3)
  retiredAt    DateTime?         @map("retired_at") @db.Timestamptz(3)
  createdAt    DateTime          @default(now()) @map("created_at") @db.Timestamptz(3)

  acceptances UserTermsAcceptance[]

  @@unique([documentType, version])
  @@index([documentType, effectiveAt, retiredAt])
  @@map("legal_document_versions")
}

model UserTermsAcceptance {
  id                     String               @id @default(uuid()) @db.Uuid
  userId                 String               @map("user_id") @db.Uuid
  legalDocumentVersionId String               @map("legal_document_version_id") @db.Uuid
  acceptedAt             DateTime             @default(now()) @map("accepted_at") @db.Timestamptz(3)
  source                 String
  requestId              String?              @map("request_id")
  user                   User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  legalDocumentVersion   LegalDocumentVersion @relation(fields: [legalDocumentVersionId], references: [id])

  @@unique([userId, legalDocumentVersionId])
  @@index([userId, acceptedAt])
  @@map("user_terms_acceptances")
}

model UserRoleMembership {
  id        String     @id @default(uuid()) @db.Uuid
  userId    String     @map("user_id") @db.Uuid
  role      UserRole
  status    UserStatus @default(active)
  createdAt DateTime   @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime   @updatedAt @map("updated_at") @db.Timestamptz(3)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role])
  @@index([role, status])
  @@map("user_role_memberships")
}

model UploaderProfile {
  id           String     @id @default(uuid()) @db.Uuid
  userId       String     @unique @map("user_id") @db.Uuid
  inviteCodeId String     @unique @map("invite_code_id") @db.Uuid
  displayName  String     @map("display_name")
  bio          String?
  status       UserStatus @default(active)
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt    DateTime   @updatedAt @map("updated_at") @db.Timestamptz(3)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  inviteCode   InviteCode @relation(fields: [inviteCodeId], references: [id])

  @@map("uploader_profiles")
}

model InviteCode {
  id              String           @id @default(uuid()) @db.Uuid
  codeHash        String           @unique @map("code_hash")
  displayPrefix   String           @map("display_prefix")
  status          InviteCodeStatus @default(unused)
  createdByUserId String           @map("created_by_user_id") @db.Uuid
  usedByUserId    String?          @map("used_by_user_id") @db.Uuid
  usedAt          DateTime?        @map("used_at") @db.Timestamptz(3)
  expiresAt       DateTime?        @map("expires_at") @db.Timestamptz(3)
  createdAt       DateTime         @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt       DateTime         @updatedAt @map("updated_at") @db.Timestamptz(3)
  createdBy       User             @relation("InviteCreatedBy", fields: [createdByUserId], references: [id])
  usedBy          User?            @relation("InviteUsedBy", fields: [usedByUserId], references: [id])
  uploaderProfile UploaderProfile?

  @@index([status, expiresAt])
  @@map("invite_codes")
}

model AdminRoleAssignment {
  id              String     @id @default(uuid()) @db.Uuid
  userId          String     @map("user_id") @db.Uuid
  adminRole       AdminRole  @map("admin_role")
  status          UserStatus @default(active)
  createdByUserId String?    @map("created_by_user_id") @db.Uuid
  createdAt       DateTime   @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt       DateTime   @updatedAt @map("updated_at") @db.Timestamptz(3)
  user            User       @relation("AdminRoleUser", fields: [userId], references: [id], onDelete: Cascade)
  createdBy       User?      @relation("AdminRoleCreatedBy", fields: [createdByUserId], references: [id])

  @@unique([userId, adminRole])
  @@index([adminRole, status])
  @@map("admin_role_assignments")
}

model ObserverProfile {
  id               String     @id @default(uuid()) @db.Uuid
  userId           String     @unique @map("user_id") @db.Uuid
  partnerName      String     @map("partner_name")
  defaultShareRate Decimal    @default(0) @map("default_share_rate") @db.Decimal(6, 4)
  status           UserStatus @default(active)
  createdAt        DateTime   @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt        DateTime   @updatedAt @map("updated_at") @db.Timestamptz(3)
  user             User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("observer_profiles")
}

model UserSession {
  id            String    @id @default(uuid()) @db.Uuid
  userId        String    @map("user_id") @db.Uuid
  tokenHash     String    @unique @map("token_hash")
  csrfTokenHash String?   @map("csrf_token_hash")
  csrfExpiresAt DateTime? @map("csrf_expires_at") @db.Timestamptz(3)
  expiresAt     DateTime  @map("expires_at") @db.Timestamptz(3)
  revokedAt     DateTime? @map("revoked_at") @db.Timestamptz(3)
  lastSeenAt    DateTime  @default(now()) @map("last_seen_at") @db.Timestamptz(3)
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([expiresAt, revokedAt])
  @@map("user_sessions")
}

model AuthChallenge {
  id             String               @id @default(uuid()) @db.Uuid
  provider       AuthProvider
  identifier     String
  identifierHash String               @map("identifier_hash")
  purpose        AuthChallengePurpose
  codeHash       String               @map("code_hash")
  attempts       Int                  @default(0)
  maxAttempts    Int                  @default(5) @map("max_attempts")
  expiresAt      DateTime             @map("expires_at") @db.Timestamptz(3)
  consumedAt     DateTime?            @map("consumed_at") @db.Timestamptz(3)
  createdAt      DateTime             @default(now()) @map("created_at") @db.Timestamptz(3)

  @@index([identifierHash, purpose, createdAt])
  @@index([expiresAt, consumedAt])
  @@map("auth_challenges")
}
